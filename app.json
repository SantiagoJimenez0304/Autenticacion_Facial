{
  "expo": {
    "name": "GeoFace",
    "slug": "geo-face-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "geofaceapp",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "La app necesita acceso a la cámara para el reconocimiento facial.",
        "NSLocationWhenInUseUsageDescription": "La app necesita tu ubicación para verificar que estés en la zona designada.",
        "NSPhotoLibraryUsageDescription": "La app necesita acceso a tus fotos para registrar perfiles faciales."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A1A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.erraser.geofaceapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A1A"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "La app necesita acceso a la cámara para reconocimiento facial."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "La app necesita tu ubicación para verificar que estés en la zona designada."
        }
      ],
      "expo-secure-store",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b497ac1c-dee6-43ea-8756-2f41f76ffc35"
      }
    }
  }
}
